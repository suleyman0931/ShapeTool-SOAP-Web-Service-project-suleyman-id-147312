<!-- ============================================================
     ShapeTool SOAP Web Service - ERROR EXAMPLES
     These examples demonstrate the improved descriptive error messages
     ============================================================ -->


<!-- ERROR 1: Negative radius -->
<soapenv:Envelope xmlns:soapenv="http://schemas.xmlsoap.org/soap/envelope/"
                  xmlns:gen="http://www.shapetool.com/gen">
   <soapenv:Header/>
   <soapenv:Body>
      <gen:circleAreaRequest>
         <gen:radius>-5.0</gen:radius>
      </gen:circleAreaRequest>
   </soapenv:Body>
</soapenv:Envelope>

<!-- Expected SOAP Fault Response for ERROR 1 -->
<SOAP-ENV:Envelope xmlns:SOAP-ENV="http://schemas.xmlsoap.org/soap/envelope/">
   <SOAP-ENV:Header/>
   <SOAP-ENV:Body>
      <SOAP-ENV:Fault>
         <faultcode>SOAP-ENV:Client</faultcode>
         <faultstring xml:lang="en">radius must be positive (greater than 0). Provided value: -5.0</faultstring>
         <detail>
            <ns2:field xmlns:ns2="http://www.shapetool.com/gen">radius</ns2:field>
            <ns2:errorMessage xmlns:ns2="http://www.shapetool.com/gen">radius must be positive (greater than 0). Provided value: -5.0</ns2:errorMessage>
         </detail>
      </SOAP-ENV:Fault>
   </SOAP-ENV:Body>
</SOAP-ENV:Envelope>


