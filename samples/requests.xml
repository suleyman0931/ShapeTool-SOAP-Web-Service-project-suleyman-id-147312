<!-- Circle Area Request -->
<soapenv:Envelope xmlns:soapenv="http://schemas.xmlsoap.org/soap/envelope/"
                  xmlns:gen="http://www.shapetool.com/gen">
   <soapenv:Header/>
   <soapenv:Body>
      <gen:circleAreaRequest>
         <gen:radius>5.0</gen:radius>
      </gen:circleAreaRequest>
   </soapenv:Body>
</soapenv:Envelope>

        <!-- Circle Area Response -->
<soapenv:Envelope xmlns:soapenv="http://schemas.xmlsoap.org/soap/envelope/"
                  xmlns:gen="http://www.shapetool.com/gen">
<soapenv:Header/>
<soapenv:Body>
   <gen:circleAreaResponse>
      <gen:area>78.53981633974483</gen:area>
   </gen:circleAreaResponse>
</soapenv:Body>
</soapenv:Envelope>

