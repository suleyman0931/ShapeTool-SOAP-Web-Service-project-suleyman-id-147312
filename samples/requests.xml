        <!-- Invalid Request (Negative Value) -->
<soapenv:Envelope xmlns:soapenv="http://schemas.xmlsoap.org/soap/envelope/"
                  xmlns:gen="http://www.shapetool.com/gen">
<soapenv:Header/>
<soapenv:Body>
   <gen:circleAreaRequest>
      <gen:radius>-5.0</gen:radius>
   </gen:circleAreaRequest>
</soapenv:Body>
</soapenv:Envelope>

        <!-- Example SOAP Fault Response for Invalid Request -->
<soapenv:Envelope xmlns:soapenv="http://schemas.xmlsoap.org/soap/envelope/">
<soapenv:Header/>
<soapenv:Body>
   <soapenv:Fault>
      <faultcode>soapenv:Client</faultcode>
      <faultstring>Validation failed: cvc-minInclusive-valid: Value '-5.0' is not facet-valid with respect to minInclusive '0.0'.</faultstring>
   </soapenv:Fault>
</soapenv:Body>
</soapenv:Envelope>